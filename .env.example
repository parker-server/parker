# Database
DATABASE_URL=sqlite:///./storage/database/comics.db
BASE_URL=/

# Comics path
# Docker Compose mounts ./comics to /comics by default.
# Local installs should set this to the folder Parker should browse from.
COMICS_PATH=/path/to/your/comics

# Unrar path
UNRAR_PATH=unrar

# Docker host port
# Parker listens on 8000 inside the container; this controls the host port.
PARKER_PORT=8000

# Security (change in production!)
SECRET_KEY=your-secret-key-here

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# The IP of your proxy (Nginx/Caddy) - use "*" only if internal network is secure
TRUSTED_PROXIES=127.0.0.1,172.18.0.1


# Cache
CACHE_DIR=./cache
THUMBNAIL_CACHE_DIR=./cache/thumbnails

# Logging
LOG_LEVEL=INFO
